# ==========================================
# .env.TEMPLATE - DO NOT COMMIT .env FILES
# ==========================================
# 
# INSTRUCTIONS:
# 1. Create a copy of this file named ".env" (add to .gitignore)
# 2. Fill in YOUR actual credentials from Azure Portal
# 3. NEVER commit the .env file to GitHub
# 4. Load these variables before running scripts
#
# SECURITY: This file should NEVER be committed to git
# IF YOU ACCIDENTALLY COMMIT THIS: Rotate credentials immediately!

# ==== Azure SQL Database Connection ====
AZURE_SQL_SERVER=your_server.database.windows.net
AZURE_SQL_DB=your_database_name
AZURE_SQL_USER=your_username
AZURE_SQL_PASSWORD=your_password_here

# ==== Optional: Full Connection String ====
# If using connection string instead:
AZURE_SQL_CONNECTION_STRING=Server=your_server.database.windows.net;Database=your_database_name;User Id=your_username;Password=your_password;

# ==== Loading Instructions ====
# PowerShell:
# $env:AZURE_SQL_SERVER = (Get-Content .env | Select-String "AZURE_SQL_SERVER").ToString().Split("=")[1]
# 
# Bash/Linux:
# export $(cat .env | xargs)
#
# Or manually set each variable:
# $env:AZURE_SQL_SERVER = "your_value"
# $env:AZURE_SQL_DB = "your_value"
# $env:AZURE_SQL_USER = "your_value"
# $env:AZURE_SQL_PASSWORD = "your_value"

# ==== Using with Scripts ====
# After setting environment variables, run:
# sqlcmd -S $env:AZURE_SQL_SERVER -d $env:AZURE_SQL_DB -U $env:AZURE_SQL_USER -P $env:AZURE_SQL_PASSWORD -i script.sql
